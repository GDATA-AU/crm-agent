# crm-agent environment configuration
# Copy this file to .env and fill in the values before starting the agent.

# ---------------------------------------------------------------------------
# Portal connection (required)
# ---------------------------------------------------------------------------
PORTAL_URL=https://your-council.lga-portal.com.au
AGENT_API_KEY=xxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Azure Blob Storage (required)
# ---------------------------------------------------------------------------
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net

# ---------------------------------------------------------------------------
# Local connection strings
# Referenced in job configs as connectionRef: "pathway-db" → CONN_PATHWAY_DB
# These never transit the network — they are only stored on the agent host.
# ---------------------------------------------------------------------------
# CONN_PATHWAY_DB=Server=192.168.1.50;Database=Pathway;User Id=readonly;Password=xxx;Encrypt=false;
# CONN_MERIT_DB=Server=192.168.1.51;Database=Merit;User Id=readonly;Password=xxx;Encrypt=false;

# ---------------------------------------------------------------------------
# Agent tuning (optional — defaults shown)
# ---------------------------------------------------------------------------
POLL_INTERVAL_MS=30000       # How often to poll the portal for jobs (ms)
HEARTBEAT_INTERVAL_MS=30000  # How often to send a heartbeat during a job (ms)
LOG_LEVEL=info               # pino log level: trace | debug | info | warn | error
